{
  "connection_types": [
    {
      "id": "HTTP INJECT",
      "description": "HTTP header injection - modifies HTTP headers to bypass DPI",
      "tls_version": "tlshello"
    },
    {
      "id": "SSL INJECT",
      "description": "SSL/TLS injection - injects into SSL handshake"
    },
    {
      "id": "SSL/TLS Direct",
      "description": "Direct SSL/TLS connection"
    },
    {
      "id": "WS (Websocket)",
      "description": "WebSocket tunneling"
    },
    {
      "id": "V2Ray",
      "description": "V2Ray/Xray protocol (VMess, VLESS, etc.)"
    },
    {
      "id": "DNSTT",
      "description": "DNS-over-HTTPS tunneling"
    }
  ],
  "protocols_supported": ["vmess", "vless", "trojan", "shadowsocks"],
  "features": {
    "vpn_modes": ["VPN", "Proxy only"],
    "per_app_proxy": true,
    "local_dns": true,
    "fake_dns": true,
    "http_proxy_append": true,
    "mux_enabled": true,
    "fragment_enabled": true,
    "subscription_auto_update": true,
    "ipv6_prefer": true,
    "proxy_sharing": true,
    "sniffing": true,
    "route_only": true,
    "boot_auto_connect": true,
    "speed_test": true,
    "ip_hunter": true,
    "wifi_tethering": true,
    "time_manager": true,
    "ssh_vpn": true,
    "openvpn": true
  },
  "tls_versions": ["tlshello", "1-2", "1-3", "1-5"],
  "dns_options": {
    "local_dns_port": 10853,
    "socks_port": 10808,
    "remote_dns": "udp/tcp/https/quic",
    "vpn_dns": "IPv4/v6 only"
  },
  "mux_settings": {
    "concurrency": 8,
    "xudp_concurrency": 8,
    "xudp_quic_options": ["reject", "allow", "skip"]
  },
  "fragment_settings": {
    "length": "50-100",
    "interval": "10-20",
    "packets": ["tlshello", "1-2", "1-3", "1-5"]
  },
  "subscription_settings": {
    "auto_update": true,
    "interval_minutes": 1440
  },
  "routing_rules": {
    "black": "custom_routing_black - blocks ads, bittorrent, udp/443",
    "white": "custom_routing_white - proxies Google, blocks ads, direct LAN",
    "global": "custom_routing_global - all traffic through proxy",
    "iran": "custom_routing_white_iran - Iran-specific bypass rules"
  },
  "base_v2ray_config": {
    "inbounds": [
      {"tag": "socks", "port": 10808, "protocol": "socks"},
      {"tag": "http", "port": 10809, "protocol": "http"}
    ],
    "outbounds": [
      {"tag": "proxy", "protocol": "vmess"},
      {"tag": "direct", "protocol": "freedom"},
      {"tag": "block", "protocol": "blackhole"}
    ]
  },
  "notes": {
    "server_configs": "NOT HARDCODED - fetched via subscription URL or user input",
    "app_base": "V2RayNG fork with additional features (HTTP inject, SSH, IP Hunter, DNSTT)",
    "developer": "renz.javacodez (same family as PIWANG NET)",
    "package": "org.hibanet.xyz",
    "drm": "Pairip license check (1 provider, runs in daemon process)"
  }
}
